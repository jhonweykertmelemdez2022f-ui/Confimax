# ============================================
# BASES DE DATOS (Contraseñas mínimo 16 caracteres)
# ============================================
POSTGRES_PASSWORD=ProdPostgres2024!Secure#789
REDIS_PASSWORD=ProdRedis2024!Secure#456
MONGO_PASSWORD=ProdMongo2024!Secure#123

# ============================================
# PGADMIN (Interfaz web PostgreSQL)
# ============================================
PGADMIN_EMAIL=admin@edulearn.com
PGADMIN_PASSWORD=PgAdmin2024!SuperSecure#Complex123

# ============================================
# MONGO EXPRESS (Interfaz web MongoDB)
# ============================================
# Usuario para login en web
MONGO_EXPRESS_USER=mongoAdmin
MONGO_EXPRESS_PASSWORD=MongoWeb2024!Secure#Admin789

# Para Traefik Basic Auth (opcional, extra de seguridad)
# Generar con: htpasswd -nb mongoAdmin MongoWeb2024!Secure#Admin789
MONGO_EXPRESS_BASIC_AUTH=mongoAdmin:$apr1$H6uskkkW$IgXLP6ewTrSuBkTrqE8wj/

# Secrets para sesiones
ME_COOKIE_SECRET=SuperSecretCookieMongo2024!@#$%^&*
ME_SESSION_SECRET=SuperSecretSessionMongo2024!@#$%^&*

# ============================================
# REDIS COMMANDER (Interfaz web Redis)
# ============================================
REDIS_COMMANDER_USER=redisAdmin
REDIS_COMMANDER_PASSWORD=RedisWeb2024!Secure#Admin456

# Para Traefik Basic Auth (opcional)
# Generar con: htpasswd -nb redisAdmin RedisWeb2024!Secure#Admin456
REDIS_COMMANDER_BASIC_AUTH=redisAdmin:$apr1$H6uskkkW$IgXLP6ewTrSuBkTrqE8wj/

# ============================================
# JWT Y SEGURIDAD
# ============================================
JWT_SECRET=SuperMegaUltraSecretJWT2024!@#$%^&*ABCDEFGHIJKLM1234567890

# ============================================
# URLs INTERNAS (No modificar)
# ============================================
DATABASE_URL=postgresql://confimax:${POSTGRES_PASSWORD}@postgres:5432/confimax
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
MONGO_URI=mongodb://confimax:${MONGO_PASSWORD}@mongo:27017/?authSource=admin

# ============================================
# COOLIFY CONFIG
# ============================================
COOLIFY_DOMAIN=confimax.bitforges.com
COOLIFY_SSL=true
