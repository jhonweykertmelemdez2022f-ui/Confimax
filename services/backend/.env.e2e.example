# ============================================
# E2E TEST ENVIRONMENT
# ============================================
# Copiar a .env.e2e y configurar con credenciales reales:
#   cp .env.e2e.example .env.e2e
#
# Estos valores se usan SOLO cuando se ejecuta:
#   npm run test:e2e

# PostgreSQL (local Docker - docker-compose.local-databases.yml)
DATABASE_URL=postgresql://confimax_admin:Jackson1@localhost:5432/confimax_produccion
# O variables separadas:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=confimax_admin
# POSTGRES_PASSWORD=Jackson1
# POSTGRES_DB=confimax_produccion

# Upstash Redis (cloud) - DESCOMENTAR si se usa Upstash real
# UPSTASH_REDIS_URL=rediss://default:TU_TOKEN@host.upstash.io:6379
# Redis local (docker-compose.local-databases.yml)
REDIS_URL=redis://:Jackson1@localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=Jackson1

# MongoDB Atlas (cloud) - DESCOMENTAR si se usa Atlas real
# ATLAS_URI=mongodb+srv://user:password@cluster.mongodb.net/confimax_logs?retryWrites=true&w=majority
# MongoDB local (docker-compose.local-databases.yml)
MONGODB_URI=mongodb://confimax:Jackson1@localhost:27017/confimax_logs?authSource=admin
# MONGO_HOST=localhost
# MONGO_PORT=27017
# MONGO_USER=confimax
# MONGO_PASSWORD=Jackson1
# MONGO_DB=confimax_logs
