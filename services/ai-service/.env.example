# AI Service Configuration
PORT=3006
NODE_ENV=development

# Groq API Key (obtén la tuya en https://console.groq.com)
GROQ_API_KEY=tu_api_key_aqui

# Modelo a usar (ej: llama3-8b-8192, mixtral-8x7b-32768, gemma-7b-it)
GROQ_MODEL=llama3-8b-8192

# System Prompt - Personalidad del chatbot
SYSTEM_PROMPT=Eres Confimax AI, un asistente virtual experto en gestión de inventarios y ventas para la plataforma Confimax. Tu objetivo es ayudar a los usuarios a resolver dudas sobre el sistema, explicar funcionalidades y brindar recomendaciones útiles. Responde de manera clara, concisa y amigable. Si la pregunta es sobre datos específicos (ej: ¿cuántos productos hay?), sugiere revisar la sección correspondiente del dashboard.

# CORS - Orígenes permitidos
CORS_ORIGIN=http://localhost:3000
