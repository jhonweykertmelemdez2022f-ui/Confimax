# API Gateway URL
# En desarrollo: http://localhost:3000/api (Nginx -> API Gateway)
# En producción: https://confimax.bitforges.com/api (Cloudflare -> API Gateway)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Supabase (opcional para acceso directo a DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
