# ============================================
# ⚠️  SEGURIDAD - INSTRUCCIONES IMPORTANTES
# ============================================
# 1. NUNCA uses este archivo directamente en producción
# 2. Copia a .env y genera contraseñas seguras con:
#    openssl rand -base64 32
# 3. Mantén el .env en .gitignore (YA DEBE ESTAR)
# 4. En producción, usa Docker Secrets o un vault
# ============================================

# 🔐 JWT Secret (mínimo 32 caracteres aleatorios)
# Generar con: openssl rand -base64 32
JWT_SECRET=CAMBIA_ESTO_EN_PRODUCCION_GENERA_UN_SECRETO_DE_32_CHARS_MIN

# 🐘 PostgreSQL
POSTGRES_USER=confimax
# Generar contraseña segura: openssl rand -base64 24
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASENA_POSTGRES
POSTGRES_DB=confimax

# ============================================
# CONFIGURACIÓN DE MEMORIA - BASES DE DATOS
# ============================================
# Ajusta estos valores según la RAM disponible en tu servidor

# PostgreSQL (máximo recomendado: 25% de RAM total del servidor)
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=100

# MongoDB (logs y notificaciones - requiere menos memoria)
MONGO_MEMORY_LIMIT=512M
MONGO_CACHE_SIZE=0.25

# Redis (caché - muy eficiente en memoria)
REDIS_MEMORY_LIMIT=256M
REDIS_MAXMEMORY=256mb

# Generar contraseñas seguras: openssl rand -base64 24
REDIS_PASSWORD=CAMBIA_ESTA_CONTRASENA_REDIS
MONGO_PASSWORD=CAMBIA_ESTA_CONTRASENA_MONGO

# Entorno (development | production)
NODE_ENV=development

# ============================================
# CONEXIÓN A BASES DE DATOS EXTERNAS
# ============================================
# Descomenta y configura si usas PostgreSQL en otro servidor:
# EXTERNAL_POSTGRES_HOST=db.externo.com
# EXTERNAL_POSTGRES_PORT=5432
# EXTERNAL_POSTGRES_USER=confimax
# EXTERNAL_POSTGRES_PASSWORD=
# EXTERNAL_POSTGRES_DB=confimax

# Para MongoDB externo:
# EXTERNAL_MONGO_HOST=mongo.externo.com
# EXTERNAL_MONGO_PORT=27017
# EXTERNAL_MONGO_USER=confimax
# EXTERNAL_MONGO_PASSWORD=
# EXTERNAL_MONGO_DB=confimax_notifications

# Para Redis externo:
# EXTERNAL_REDIS_HOST=redis.externo.com
# EXTERNAL_REDIS_PORT=6379
# EXTERNAL_REDIS_PASSWORD=

# ============================================
# PGADMIN - Interfaz web para PostgreSQL
# ============================================
# ⚠️  En producción: usar HTTPS (nginx reverse proxy) o VPN
# ⚠️  NUNCA expongas pgAdmin directamente a internet sin protección
PGADMIN_EMAIL=admin@confimax.com
# Generar contraseña segura: openssl rand -base64 12
PGADMIN_PASSWORD=CAMBIA_ESTA_CONTRASENA_PGADMIN
PGADMIN_PORT=5050

# ============================================
# � SUPABASE - PostgreSQL en la nube
# ============================================
# URL completa de conexión (reemplaza todas las variables de PostgreSQL)
# Formato: postgresql://user:password@host:5432/db?schema=public
# DATABASE_URL="postgresql://postgres:password@db.project.supabase.co:5432/postgres?schema=public"

# Variables individuales (alternativa a DATABASE_URL)
# POSTGRES_HOST=db.project.supabase.co
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your-password
# POSTGRES_DB=postgres
# POSTGRES_SSL=true

# Supabase API (para auth, storage, realtime)
# SUPABASE_URL=https://project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# ============================================
# �📦 PRISMA ORM - URL de conexión
# ============================================
# Para desarrollo local con Docker:
DATABASE_URL="postgresql://confimax:CAMBIA_ESTA_CONTRASENA_POSTGRES@localhost:5432/confimax?schema=public"

# Para Supabase (con SSL):
# DATABASE_URL="postgresql://postgres:password@db.project.supabase.co:5432/postgres?sslmode=require&schema=public"

# ============================================
# 📊 MONGODB - Logs y Eventos
# ============================================
# URL de conexión a MongoDB para logs de la plataforma educativa
MONGODB_URI="mongodb://confimax:CAMBIA_ESTA_CONTRASENA_MONGO@localhost:27017/confimax_logs?authSource=admin"

# Para producción (con SSL):
# MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/confimax_logs?retryWrites=true&w=majority"

# ============================================
# ⚡ REDIS - Caché y Rate Limiting
# ============================================
# URL de conexión a Redis
REDIS_URL="redis://:CAMBIA_ESTA_CONTRASENA_REDIS@localhost:6379/0"

# Opciones avanzadas de Redis (opcional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIA_ESTA_CONTRASENA_REDIS
REDIS_DB=0

# ============================================
# ☁️  CLOUD CONNECTIONS - PRODUCCIÓN
# ============================================
# Descomenta y configura estas variables para usar servicios cloud
# en producción en lugar de las bases de datos locales.

# --- SUPABASE (PostgreSQL Cloud) ---
# SUPABASE_DATABASE_URL="postgresql://postgres:password@db.project.supabase.co:5432/postgres?sslmode=require&schema=public"
# SUPABASE_HOST=db.project.supabase.co
# SUPABASE_PORT=5432
# SUPABASE_USER=postgres
# SUPABASE_PASSWORD=your-supabase-password
# SUPABASE_DB=postgres
# SUPABASE_SSL=true

# Supabase API (Auth, Storage, Realtime)
# SUPABASE_URL=https://project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key

# --- MONGODB ATLAS (MongoDB Cloud) ---
# ATLAS_URI="mongodb+srv://user:password@cluster.mongodb.net/confimax_logs?retryWrites=true&w=majority"
# ATLAS_HOST=cluster.mongodb.net
# ATLAS_PORT=27017
# ATLAS_USER=atlas-user
# ATLAS_PASSWORD=your-atlas-password
# ATLAS_DB=confimax_logs
# ATLAS_AUTH_SOURCE=admin
# ATLAS_RETRY_WRITES=true
# ATLAS_W=majority

# --- UPSTASH (Redis Cloud) ---
# UPSTASH_REDIS_URL="rediss://default:token@host.upstash.io:6379"
# UPSTASH_REDIS_REST_URL="https://host.upstash.io"
# UPSTASH_REDIS_HOST=host.upstash.io
# UPSTASH_REDIS_PORT=6379
# UPSTASH_REDIS_PASSWORD=your-upstash-token
# UPSTASH_REDIS_TOKEN=your-upstash-token
# UPSTASH_REDIS_TLS=true

# ============================================================================
# API GATEWAY
# ============================================================================
GATEWAY_PORT=8080
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# ============================================================================
# TAILSCALE VPN (Mesh VPN para seguridad entre servicios)
# ============================================================================
# 1. Crea una cuenta en https://login.tailscale.com
# 2. Ve a Settings > Keys y genera un Reusable Auth Key
# 3. Pega el valor aqui (sin comillas)
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx
TS_HOSTNAME=confimax-backend

# ============================================================================
# FABIANA SERVICE - Groq API
# ============================================================================
# Obtén tu API Key en https://console.groq.com
GROQ_API_KEY=tu_api_key_de_groq_aqui

# Modelo a usar (opciones: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma-7b-it)
GROQ_MODEL=llama-3.1-8b-instant

# System Prompt - Personalidad del chatbot (opcional)
SYSTEM_PROMPT=Eres Fabiana, el asistente virtual de Confimax. Eres experta en gestión de inventarios y ventas para la plataforma Confimax. Tu objetivo es ayudar a los usuarios a resolver dudas sobre el sistema, explicar funcionalidades y brindar recomendaciones útiles. Responde de manera clara, concisa y amigable. Si la pregunta es sobre datos específicos (ej: ¿cuántos productos hay?), sugiere revisar la sección correspondiente del dashboard.
